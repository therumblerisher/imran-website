---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const writing = (await getCollection('writing'))
  .filter((entry) => entry.data.state === 'published')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en', {
    month: 'short',
    year: 'numeric',
  }).format(date);

const elsewhere = [
  {
    label: 'X',
    value: '@therumblerisher',
    href: 'https://x.com/therumblerisher',
  },
  {
    label: 'GitHub',
    value: 'therumblerisher',
    href: 'https://github.com/therumblerisher',
  },
  {
    label: 'Email',
    value: 'imranhq957@gmail.com',
    href: 'mailto:imranhq957@gmail.com',
  },
];

const projects = [
  {
    name: 'Keystone Lab',
    description: 'Product work in Singapore, building software that should turn into revenue, not just demos.',
  },
  {
    name: 'Entropic Labs',
    description: 'My personal product studio for small internet products, experiments, and bespoke builds.',
  },
  {
    name: 'Kira',
    description: 'Receipt splitting for group meals. Scan a receipt, share a link, let friends claim their items.',
  },
  {
    name: 'Panora',
    description: 'An AI notebook for meetings, conversations, and the messy middle of thinking with agents.',
  },
];

const thoughts = [
  'What it actually costs to participate in modern KL life, not just survive it.',
  'How to close the gap between building good products and getting people to care.',
  'What small teams can realistically delegate to AI agents without creating more work.',
];
---

<BaseLayout>
  <header class="home-header" id="top">
    <p class="eyebrow">Imran Haqeem</p>
    <h1 class="site-title">Imran Haqeem</h1>
    <p class="lede">I build software products and write about the economics of everyday life in Malaysia.</p>
    <p class="intro">
      I work on product at Keystone Lab, build my own things under Entropic Labs, and use this site as the public notebook for what I’m learning along the way.
    </p>

    <nav class="section-nav" aria-label="Section navigation">
      <a href="#writing">Writing</a>
      <span aria-hidden="true">•</span>
      <a href="#projects">Projects</a>
      <span aria-hidden="true">•</span>
      <a href="#thinking">Currently thinking</a>
      <span aria-hidden="true">•</span>
      <a href="#elsewhere">Elsewhere</a>
    </nav>
  </header>

  <section class="section" id="writing" aria-labelledby="writing-title">
    <div class="section-header">
      <h2 class="section-title" id="writing-title">Writing</h2>
      <a class="section-link" href="/writing/">Full archive</a>
    </div>

    {writing.length > 0 ? (
      <ol class="writing-list">
        {writing.map((entry) => (
          <li class="writing-item">
            <a class="writing-link" href={`/writing/${entry.slug}/`}>
              {entry.data.title}
            </a>
            <span class="writing-meta">{formatDate(entry.data.date)}</span>
          </li>
        ))}
      </ol>
    ) : (
      <p class="empty-note">First essay coming soon. Probably something unreasonably specific about money, taste, and daily life in Malaysia.</p>
    )}
  </section>

  <section class="section" id="projects" aria-labelledby="projects-title">
    <div class="section-header">
      <h2 class="section-title" id="projects-title">Projects</h2>
      <p class="section-description">Selected work and current experiments.</p>
    </div>

    <ul class="thinking-list">
      {projects.map((project) => (
        <li class="thinking-item">
          <span class="elsewhere-label">{project.name}</span>
          <span>{project.description}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="section" id="thinking" aria-labelledby="thinking-title">
    <div class="section-header">
      <h2 class="section-title" id="thinking-title">Currently thinking</h2>
      <p class="section-description">Questions worth keeping in view.</p>
    </div>

    <ul class="thinking-list">
      {thoughts.map((thought) => (
        <li class="thinking-item">
          <span class="elsewhere-label">Note</span>
          <span>{thought}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="section" id="elsewhere" aria-labelledby="elsewhere-title">
    <div class="section-header">
      <h2 class="section-title" id="elsewhere-title">Elsewhere</h2>
      <p class="section-description">A few places I live online.</p>
    </div>

    <ul class="elsewhere-list">
      {elsewhere.map((item) => (
        <li class="elsewhere-item">
          <span class="elsewhere-label">{item.label}</span>
          <a class="elsewhere-value" href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noreferrer' : undefined}>
            {item.value}
          </a>
        </li>
      ))}
    </ul>
  </section>

  <footer class="footer">
    <p>
      Reach me at <a href="mailto:imranhq957@gmail.com">imranhq957@gmail.com</a> or on
      <a href="https://x.com/therumblerisher" target="_blank" rel="noreferrer">X</a>.
    </p>
  </footer>
</BaseLayout>
