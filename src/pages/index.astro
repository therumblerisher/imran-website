---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const writing = (await getCollection('writing')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en', {
    month: 'short',
    year: 'numeric',
  }).format(date);

const elsewhere = [
  {
    label: 'X',
    value: '@therumblerisher',
    href: 'https://x.com/therumblerisher',
  },
  {
    label: 'GitHub',
    value: 'therumblerisher',
    href: 'https://github.com/therumblerisher',
  },
  {
    label: 'Email',
    value: 'imranhq957@gmail.com',
    href: 'mailto:imranhq957@gmail.com',
  },
];

const projects = [
  {
    name: 'Kira',
    description: 'A receipt-splitting app built to make shared expenses less annoying.',
  },
  {
    name: 'TaxFind',
    description: 'A Malaysian tax-deduction finder built to make claims clearer and easier.',
  },
  {
    name: 'Panora',
    description: 'An AI-first notebook for agentic meeting notes, conversations, and thinking.',
  },
];

const thoughts = [
  'How software agents change the way small teams build and operate.',
  'Why the economics of daily life in Malaysia shapes behavior more than people admit.',
  'What makes an internet product quietly useful enough to become part of someone\'s routine.',
];
---

<BaseLayout>
  <header class="home-header" id="top">
    <p class="eyebrow">Imran Haqeem</p>
    <h1 class="site-title">Imran Haqeem</h1>
    <p class="lede">Building internet products in Kuala Lumpur. Writing about software and the economics of everyday life in Malaysia.</p>
    <p class="intro">
      Essays and working notes on what I’m learning, building, and trying to understand.
    </p>

    <nav class="section-nav" aria-label="Section navigation">
      <a href="#projects">Projects</a>
      <span aria-hidden="true">•</span>
      <a href="#writing">Writing</a>
      <span aria-hidden="true">•</span>
      <a href="#elsewhere">Elsewhere</a>
      <span aria-hidden="true">•</span>
      <a href="#thinking">Currently thinking</a>
    </nav>
  </header>

  <section class="section" id="projects" aria-labelledby="projects-title">
    <div class="section-header">
      <h2 class="section-title" id="projects-title">Projects</h2>
      <p class="section-description">A few things I’m building and exploring.</p>
    </div>

    <ul class="thinking-list">
      {projects.map((project) => (
        <li class="thinking-item">
          <span class="elsewhere-label">{project.name}</span>
          <span>{project.description}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="section" id="writing" aria-labelledby="writing-title">
    <div class="section-header">
      <h2 class="section-title" id="writing-title">Writing</h2>
      <a class="section-link" href="/writing/">Full archive</a>
    </div>

    <ol class="writing-list">
      {writing.map((entry) => (
        <li class="writing-item">
          <a class="writing-link" href={`/writing/${entry.slug}/`}>
            {entry.data.title}
            {entry.data.state === 'draft' && <span class="pill">Draft</span>}
          </a>
          <span class="writing-meta">{formatDate(entry.data.date)}</span>
        </li>
      ))}
    </ol>
  </section>

  <section class="section" id="elsewhere" aria-labelledby="elsewhere-title">
    <div class="section-header">
      <h2 class="section-title" id="elsewhere-title">Elsewhere</h2>
      <p class="section-description">A few places I live online.</p>
    </div>

    <ul class="elsewhere-list">
      {elsewhere.map((item) => (
        <li class="elsewhere-item">
          <span class="elsewhere-label">{item.label}</span>
          <a class="elsewhere-value" href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noreferrer' : undefined}>
            {item.value}
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section class="section" id="thinking" aria-labelledby="thinking-title">
    <div class="section-header">
      <h2 class="section-title" id="thinking-title">Currently thinking</h2>
      <p class="section-description">Questions worth keeping in view.</p>
    </div>

    <ul class="thinking-list">
      {thoughts.map((thought) => (
        <li class="thinking-item">
          <span class="elsewhere-label">Note</span>
          <span>{thought}</span>
        </li>
      ))}
    </ul>
  </section>

  <footer class="footer">
    <p>
      Reach me at <a href="mailto:imranhq957@gmail.com">imranhq957@gmail.com</a> or on
      <a href="https://x.com/therumblerisher" target="_blank" rel="noreferrer">X</a>.
    </p>
  </footer>
</BaseLayout>
